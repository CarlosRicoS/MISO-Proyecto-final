{
  "name": "travelhub",
  "version": "0.0.0",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "config:env": "node scripts/generate-config.mjs",
    "ng": "ng",
    "start": "npm run config:env && ng serve",
    "start:app": "npm run config:env && ng serve app --port 4200",
    "start:portal-hoteles": "ng serve portal-hoteles --port 4201",
    "start:wiremock": "API_BASE_URL=http://localhost:8080 PROPERTY_API_PATH=/poc-properties/api/property PROPERTY_API_TOKEN= npm run start",
    "build": "npm run config:env && ng build",
    "build:app": "npm run config:env && ng build app",
    "build:portal-hoteles": "ng build portal-hoteles",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:app": "ng test app",
    "test:portal-hoteles": "ng test portal-hoteles --watch=false",
    "android:sync": "npm run config:env && npx ionic build && npx cap sync android",
    "android:sync:wiremock": "API_BASE_URL=http://10.0.2.2:8080 PROPERTY_API_PATH=/poc-properties/api/property PROPERTY_API_TOKEN= node scripts/generate-config.mjs && npx ionic build && npx cap sync android",
    "e2e": "npm run e2e:web",
    "e2e:web": "npx playwright test e2e/web",
    "e2e:web:ui": "npx playwright test e2e/web --ui",
    "e2e:web:with-app": "npx start-server-and-test \"npm run start -- --host 0.0.0.0 --port 4200\" http://localhost:4200 \"npm run e2e:web\"",
    "e2e:web:with-wiremock": "API_BASE_URL=http://localhost:8080 PROPERTY_API_PATH=/poc-properties/api/property PROPERTY_API_TOKEN= npm run e2e:web:with-app",
    "e2e:portal-hoteles": "npx playwright test --config=playwright-portal-hoteles.config.ts",
    "e2e:portal-hoteles:ui": "npx playwright test --config=playwright-portal-hoteles.config.ts --ui",
    "e2e:portal-hoteles:with-app": "npx start-server-and-test \"npm run start:portal-hoteles -- --host 0.0.0.0\" http://localhost:4201 \"npm run e2e:portal-hoteles\"",
    "e2e:android": "npm run android:sync && cd android && ./gradlew connectedDebugAndroidTest",
    "e2e:android:with-wiremock": "npm run android:sync:wiremock && cd android && ./gradlew connectedDebugAndroidTest",
    "e2e:android:espresso": "npm run android:sync && cd android && ./gradlew connectedDebugAndroidTest -Pandroid.testInstrumentationRunnerArguments.class=com.uniandes.travelhub.app.TravelHubEspressoTest",
    "e2e:android:espresso:with-wiremock": "npm run android:sync:wiremock && cd android && ./gradlew connectedDebugAndroidTest -Pandroid.testInstrumentationRunnerArguments.class=com.uniandes.travelhub.app.TravelHubEspressoTest",
    "e2e:android:espresso:script": "bash scripts/run-android-espresso-tests.sh",
    "e2e:android:espresso:script:wiremock": "bash scripts/run-android-espresso-tests.sh --wiremock",
    "e2e:android:espresso:script:auto-emulator": "bash scripts/run-android-espresso-tests.sh --start-emulator",
    "e2e:android:espresso:script:auto-emulator:wiremock": "bash scripts/run-android-espresso-tests.sh --start-emulator --wiremock",
    "e2e:android:espresso:ci": "bash scripts/run-android-espresso-tests.sh --ci",
    "e2e:android:espresso:ci:wiremock": "bash scripts/run-android-espresso-tests.sh --ci --wiremock",
    "lint": "ng lint",
    "lint:guardrails": "node scripts/check-frontend-guardrails.mjs --changed",
    "lint:guardrails:enable": "node scripts/check-frontend-guardrails.mjs --enable --changed",
    "lint:guardrails:all": "node scripts/check-frontend-guardrails.mjs --all",
    "lint:guardrails:all:enable": "node scripts/check-frontend-guardrails.mjs --enable --all",
    "lint:guardrails:disable": "node scripts/check-frontend-guardrails.mjs --disable --changed",
    "lint:ci": "npm run lint && npm run lint:guardrails",
    "prepare": "cd .. && git config core.hooksPath .githooks && chmod +x .githooks/pre-commit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@ionic/angular": "^8.0.0",
    "ionicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/language-service": "^20.0.0",
    "@axe-core/playwright": "^4.11.2",
    "@capacitor/cli": "^8.2.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@playwright/test": "^1.54.2",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "start-server-and-test": "^2.0.10",
    "typescript": "~5.9.0"
  }
}
